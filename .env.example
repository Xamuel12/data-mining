# ==========================================
# CultureExplore - Environment Variables
# ==========================================

# Required: Flask secret key (generate a strong random string)
SECRET_KEY=your-super-secret-key-here-change-this

# Required for production: PostgreSQL database URL
# Get free PostgreSQL from: https://neon.tech or https://supabase.com
# Format: postgresql://user:password@host:port/database
DATABASE_URL=sqlite:///users.db

# Optional: Set to 'production' on live servers
FLASK_ENV=development
