# Copy this file to .env and fill in your actual values for local development
# For Vercel/Render, add these in your dashboard under Environment Variables

# Required: A long random string for Flask sessions
# Generate one at: https://randomkeygen.com
SECRET_KEY=your-super-secret-random-key-here

# Required in production: PostgreSQL connection string
# Get a free database from:
#   - Neon: https://neon.tech (Recommended)
#   - Supabase: https://supabase.com
# Format: postgresql://username:password@hostname:port/database_name
DATABASE_URL=postgresql://user:password@ep-example.us-east-1.aws.neon.tech/dbname

# Optional: Set to 'production' on your deployed app
FLASK_ENV=development

